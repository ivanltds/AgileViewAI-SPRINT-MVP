{
  "name": "agileviewai-tests",
  "version": "1.0.0",
  "description": "BDD Tests for AgileViewAI modularization",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --verbose",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:vault": "node --experimental-vm-modules node_modules/.bin/jest tests/bdd/vault.feature.test.js --verbose",
    "test:times": "node --experimental-vm-modules node_modules/.bin/jest tests/bdd/times.feature.test.js --verbose",
    "test:sync": "node --experimental-vm-modules node_modules/.bin/jest tests/bdd/sync.feature.test.js --verbose",
    "test:bdd": "node --experimental-vm-modules node_modules/.bin/jest tests/bdd/ --verbose",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/unit/ --verbose",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration/ --verbose",
    "test:ci": "node --experimental-vm-modules node_modules/.bin/jest --coverage --ci --forceExit"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "collectCoverageFrom": [
      "**/src/**/*.js",
      "!**/tests/**",
      "!**/node_modules/**",
      "!**/dist/**"
    ],
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov",
      "html"
    ],
    "coverageThresholds": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "verbose": true
  }
}
