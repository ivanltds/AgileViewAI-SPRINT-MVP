{
  "name": "agileviewai-tests",
  "version": "1.0.0",
  "description": "BDD Tests for AgileViewAI modularization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:vault": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/bdd/vault.feature.test.js --verbose",
    "test:times": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/bdd/times.feature.test.js --verbose",
    "test:sync": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/bdd/sync.feature.test.js --verbose",
    "test:bdd": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/bdd/ --verbose",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/ --verbose",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration/ --verbose",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --ci --forceExit",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@playwright/test": "^1.59.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "vite": "^5.0.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "collectCoverageFrom": [
      "**/src/**/*.js",
      "!**/tests/**",
      "!**/node_modules/**",
      "!**/dist/**"
    ],
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "verbose": true
  }
}
